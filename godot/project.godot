; Engine configuration file for FarmRush — a Catan-style board game.
; Open this folder in Godot 4.x (4.2+) to edit, run, and export for Steam.

config_version=5

[application]

config/name="FarmRush"
config/description="A cozy, Catan-style hex board game with single-player AI, local hotseat, and online multiplayer."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.2")
config/icon="res://icon.svg"

[autoload]

Net="*res://scripts/net/NetworkManager.gd"
Game="*res://scripts/core/GameManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=800
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.34, 0.62, 0.86, 1)
